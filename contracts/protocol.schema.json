{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://localhost/contracts/authorized-security-agent/protocol-1.0.schema.json",
  "title": "Authorized Security Agent Protocol",
  "description": "Language-neutral wire contracts for the browser extension and loopback agent.",
  "type": "object",
  "$defs": {
    "contractVersion": {
      "type": "string",
      "const": "1.0"
    },
    "commandType": {
      "type": "string",
      "enum": [
        "start-scan",
        "stop-scan",
        "pause-scan",
        "resume-scan"
      ]
    },
    "commandEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contractVersion",
        "commandId",
        "commandType",
        "payload"
      ],
      "properties": {
        "contractVersion": {
          "$ref": "#/$defs/contractVersion"
        },
        "commandId": {
          "type": "string",
          "format": "uuid"
        },
        "commandType": {
          "$ref": "#/$defs/commandType"
        },
        "payload": {
          "type": "object"
        }
      }
    },
    "scanEventType": {
      "type": "string",
      "enum": [
        "queued",
        "started",
        "progress",
        "paused",
        "completed",
        "failed",
        "stopped"
      ]
    },
    "scanEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contractVersion",
        "eventId",
        "scanId",
        "eventType",
        "occurredAt"
      ],
      "properties": {
        "contractVersion": {
          "$ref": "#/$defs/contractVersion"
        },
        "eventId": {
          "type": "string",
          "format": "uuid"
        },
        "scanId": {
          "type": "string",
          "format": "uuid"
        },
        "eventType": {
          "$ref": "#/$defs/scanEventType"
        },
        "occurredAt": {
          "type": "string",
          "format": "date-time"
        },
        "message": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 500
        },
        "progressPercent": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "severity": {
      "type": "string",
      "enum": [
        "informational",
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "findingStatus": {
      "type": "string",
      "enum": [
        "open",
        "accepted-risk",
        "false-positive",
        "resolved"
      ]
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contractVersion",
        "id",
        "scanId",
        "ruleId",
        "title",
        "category",
        "severity",
        "confidence",
        "affectedUrl",
        "testMethod",
        "evidence",
        "riskDescription",
        "remediation",
        "references",
        "status",
        "firstDetectedAt",
        "lastDetectedAt"
      ],
      "properties": {
        "contractVersion": {
          "$ref": "#/$defs/contractVersion"
        },
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "scanId": {
          "type": "string",
          "format": "uuid"
        },
        "ruleId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "category": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "severity": {
          "$ref": "#/$defs/severity"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "affectedUrl": {
          "type": "string",
          "format": "uri"
        },
        "affectedParameter": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 200
        },
        "testMethod": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "evidence": {
          "type": "string",
          "maxLength": 4000
        },
        "riskDescription": {
          "type": "string",
          "maxLength": 4000
        },
        "remediation": {
          "type": "string",
          "maxLength": 4000
        },
        "references": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          },
          "uniqueItems": true
        },
        "status": {
          "$ref": "#/$defs/findingStatus"
        },
        "firstDetectedAt": {
          "type": "string",
          "format": "date-time"
        },
        "lastDetectedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "scanRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contractVersion",
        "targetUrl",
        "authorizedOrigin",
        "authorizationConfirmed",
        "mode",
        "activeVerificationConfirmed"
      ],
      "properties": {
        "contractVersion": {
          "$ref": "#/$defs/contractVersion"
        },
        "targetUrl": {
          "type": "string",
          "format": "uri"
        },
        "authorizedOrigin": {
          "type": "string",
          "format": "uri"
        },
        "authorizationConfirmed": {
          "type": "boolean",
          "const": true
        },
        "mode": {
          "type": "string",
          "enum": [
            "baseline",
            "active-verification"
          ]
        },
        "activeVerificationConfirmed": {
          "type": "boolean"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "active-verification"
              }
            }
          },
          "then": {
            "properties": {
              "activeVerificationConfirmed": {
                "const": true
              }
            }
          }
        }
      ]
    },
    "scanSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "totalChecks",
        "requestsSent",
        "totalFindings",
        "critical",
        "high",
        "medium",
        "low",
        "informational"
      ],
      "properties": {
        "totalChecks": {
          "type": "integer",
          "minimum": 0
        },
        "requestsSent": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20
        },
        "totalFindings": {
          "type": "integer",
          "minimum": 0
        },
        "critical": {
          "type": "integer",
          "minimum": 0
        },
        "high": {
          "type": "integer",
          "minimum": 0
        },
        "medium": {
          "type": "integer",
          "minimum": 0
        },
        "low": {
          "type": "integer",
          "minimum": 0
        },
        "informational": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "scanReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contractVersion",
        "scanId",
        "targetUrl",
        "mode",
        "startedAt",
        "completedAt",
        "summary",
        "checksPerformed",
        "findings",
        "scopeNote"
      ],
      "properties": {
        "contractVersion": {
          "$ref": "#/$defs/contractVersion"
        },
        "scanId": {
          "type": "string",
          "format": "uuid"
        },
        "targetUrl": {
          "type": "string",
          "format": "uri"
        },
        "mode": {
          "type": "string",
          "enum": [
            "baseline",
            "active-verification"
          ]
        },
        "startedAt": {
          "type": "string",
          "format": "date-time"
        },
        "completedAt": {
          "type": "string",
          "format": "date-time"
        },
        "summary": {
          "$ref": "#/$defs/scanSummary"
        },
        "checksPerformed": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "uniqueItems": true
        },
        "findings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/finding"
          }
        },
        "scopeNote": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        }
      }
    },
    "errorResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contractVersion",
        "errorCode",
        "message",
        "traceId"
      ],
      "properties": {
        "contractVersion": {
          "$ref": "#/$defs/contractVersion"
        },
        "errorCode": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "traceId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "errors": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 500
            }
          }
        }
      }
    }
  }
}
